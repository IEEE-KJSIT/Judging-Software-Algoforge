rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Live leaderboard / projector: anyone can READ teams, ratings, session (no login).
    // Writes still require sign-in (judges + admin).
    match /teams/{teamId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /ratings/{ratingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /session/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User profiles — authenticated only (emails & roles not public)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
